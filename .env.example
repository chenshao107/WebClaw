# ╔══════════════════════════════════════════════════════════╗
# ║              WebClaw 环境变量配置                           ║
# ╚══════════════════════════════════════════════════════════╝
#
# 快速开始：复制此文件为 .env，然后填入你的 API Key 即可
#
# ============================================================
# 1. LLM 配置（必填）
# ============================================================

# OpenAI API Key
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxx

# [可选] 使用兼容 OpenAI 的第三方 API
# DeepSeek: https://platform.deepseek.com
# 取消下面注释并填写 API Key 即可使用
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

# ============================================================
# 2. 浏览器配置（可选）
# ============================================================

# 无头模式（true=不显示浏览器窗口，适合服务器）
BROWSER_HEADLESS=false

# Chrome 调试端口（留空则自动启动新浏览器）
# 如果你已运行 scripts/start_chrome.bat，填写 9222
BROWSER_DEBUG_PORT=9222

# 浏览器窗口大小
BROWSER_VIEWPORT_WIDTH=1920
BROWSER_VIEWPORT_HEIGHT=1080

# 操作延迟（毫秒，用于调试）
BROWSER_SLOW_MO=0

# ============================================================
# 3. MCP 工具开关（可选）
# ============================================================

# browser_help - 查看可用工具和浏览器状态
MCP_ENABLE_HELP=true

# execute_python - 执行 Python 代码操作浏览器
MCP_ENABLE_PYTHON=true

# agent_task - AI 代理自动执行任务（默认关闭，耗费 token）
MCP_ENABLE_AGENT=false

# 经验管理工具 - 记录和查询操作经验
MCP_ENABLE_EXPERIENCE=true

# ============================================================
# 4. Agent 配置（可选）
# ============================================================

# 代理最大执行步数
AGENT_MAX_STEPS=25
